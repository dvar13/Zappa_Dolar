{
    "dev": {
        "app_function": "app.api_get",
        "aws_region": "us-east-1",
        "exclude": [
            "boto3",
            "dateutil",
            "botocore",
            "s3transfer",
            "concurrent"
        ],
        "project_name": "zappa-code",
        "runtime": "python3.10",
        "s3_bucket": "${BUCKET_NAME}",
        "keep_warm": false,
        "apigateway_enabled": false,
        "manage_roles": false,
        "role_name": "Labrole",
        "environment_variables": {
            "BUCKET_NAME": "${BUCKET_NAME}"
        },
        "events": [
            {
                "function": "app.api_get",
                "expression": "cron(0 2 ? * * *)"
            }
        ]
    },
    "db": {
        "app_function": "db_loader.upload",
        "aws_region": "us-east-1",
        "exclude": [
            "boto3",
            "dateutil",
            "botocore",
            "s3transfer",
            "concurrent"
        ],
        "project_name": "zappa-db-loader",
        "runtime": "python3.10",
        "s3_bucket": "${BUCKET_NAME}",
        "keep_warm": false,
        "apigateway_enabled": false,
        "manage_roles": false,
        "role_name": "Labrole",
        "environment_variables": {
            "DB_HOST": "${DB_HOST}",
            "DB_USER": "${DB_USER}",
            "DB_PASS": "${DB_PASS}",
            "DB_NAME": "${DB_NAME}"
        },
        "events": [
            {
                "function": "db_loader.upload",
                "event_source": {
                    "arn": "arn:aws:s3:::dolar-raw-eltimes",
                    "events": ["s3:ObjectCreated:*"],
                    "filters": [
                        {
                            "name": "suffix",
                            "value": ".json"
                        }
                    ]
                }
            }
        ]
    }
}